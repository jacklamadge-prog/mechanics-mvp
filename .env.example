# NVIDIA — required for AI chat (server-side only)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://your-nvidia-api-base/v1
NVIDIA_MODEL=your-org/your-model

# Speed: keep thinking OFF (default). Set true only if you need it (slower).
# NVIDIA_ENABLE_THINKING=false
# NVIDIA_MAX_TOKENS=400
# NVIDIA_TEMPERATURE=0.7

# Resend — required for email (free: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=hello@yourdomain.com
OWNER_EMAIL=you@example.com
